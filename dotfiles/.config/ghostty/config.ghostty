# Ghostty configuration tailored to cY's daily workflow:
# - Node / pnpm, Python, Rust
# - iOS / Xcode
# - Godot / Cocos / web game projects
# - many projects open in parallel under ~/dev

# Start from the main workspace root when Ghostty is launched from the Dock
# or other GUI entry points.
working-directory = /Users/cY/dev

# Display: readable, stable, good enough for mixed code/log/CJK text.
font-family = Menlo
font-family = "PingFang SC"
font-size = 15
window-theme = dark
window-width = 138
window-height = 38
window-padding-x = 10
window-padding-y = 8
window-padding-balance = true
window-step-resize = true

# Use the tab-integrated title bar. This fits a multi-project workflow better
# than floating many independent windows on macOS 14+.
macos-titlebar-style = tabs
window-save-state = always
window-new-tab-position = current
window-inherit-working-directory = true
tab-inherit-working-directory = true
split-inherit-working-directory = true
window-inherit-font-size = true

# Input and clipboard behavior tuned for terminal-heavy development.
copy-on-select = false
selection-clear-on-copy = true
right-click-action = copy-or-paste
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
mouse-hide-while-typing = true
cursor-click-to-move = true
confirm-close-surface = true

# Keep enough logs around for builds, test runs, Gradle, Xcode, Godot exports.
scrollback-limit = 100000000

# Make zsh integration explicit so cwd inheritance, prompt jumping, and
# command-finished notifications stay reliable.
shell-integration = zsh
shell-integration-features = cursor,sudo,title,ssh-env,path
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 8s

# Quick terminal: a drop-down scratchpad for one-off commands without changing
# the current window layout.
quick-terminal-position = top
quick-terminal-size = 34%,100%
quick-terminal-screen = main
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.08

# Keep left Option as Alt/Meta for shells and terminal apps, while preserving
# the right Option key for macOS character input if needed.
macos-option-as-alt = left
macos-auto-secure-input = true
macos-secure-input-indication = true

# Use Ghostty's built-in Catppuccin Mocha theme.
theme = "Catppuccin Mocha"
background-opacity = 0.7
background-opacity-cells = true
background-blur = macos-glass-regular

# Keybindings for project-heavy development.
keybind = global:cmd+backquote=toggle_quick_terminal
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:up
keybind = cmd+alt+down=goto_split:down
keybind = cmd+ctrl+left=resize_split:left,60
keybind = cmd+ctrl+right=resize_split:right,60
keybind = cmd+ctrl+up=resize_split:up,40
keybind = cmd+ctrl+down=resize_split:down,40
keybind = cmd+alt+z=toggle_split_zoom
keybind = cmd+alt+e=equalize_splits
keybind = cmd+shift+up=jump_to_prompt:-1
keybind = cmd+shift+down=jump_to_prompt:1
keybind = cmd+comma=open_config
keybind = cmd+shift+r=reload_config
keybind = cmd+1=goto_tab:1
keybind = cmd+2=goto_tab:2
keybind = cmd+3=goto_tab:3
keybind = cmd+4=goto_tab:4
keybind = cmd+5=goto_tab:5
keybind = cmd+6=goto_tab:6
keybind = cmd+7=goto_tab:7
keybind = cmd+8=goto_tab:8
keybind = cmd+9=goto_tab:9

# If you want a stronger glass effect later, lower background-opacity
# slightly, for example to 0.90 or 0.88.
